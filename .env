# Google OAuth Implementation - Environment Variables

PROFILE=local
NODE_ENV=development

PORT=3010

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Database Configuration
DB_TYPE=postgres
DB_USERNAME=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_DATABASE=Flowbrand
DB_PORT=5432
DB_NAME=Flowbrand
DB_ENTITIES=dist/src/modules/**/entities/**/*.entity{.ts,.js}
DB_MIGRATIONS=dist/src/database/migrations/*{.ts,.js}

# Google OAuth 2.0 Credentials
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_REDIRECT_URI=http://localhost:3008/api/v1/auth/google/callback

# JwT Secrets 
JWT_SECRET=your-jwt-secret
JWT_EXPIRY_TIMEFRAME=360000
JWT_REFRESH_EXPIRY_TIMEFRAME=604800
